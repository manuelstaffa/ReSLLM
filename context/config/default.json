{
    "openai_api": {
        "api_key": "",
        "base_url": "https://api.openai.com/v1",
        "model": "gpt-4o",
        "max_tokens": 4096,
        "temperature": 0.7,
        "top_p": 1.0,
        "frequency_penalty": 0.0,
        "presence_penalty": 0.0
    },
    "prompt": {
        "system": "You are a helpful assistant.",
        "user": "User: {input}",
        "assistant": "Assistant: {output}"
    },
    "logging": {
        "level": "info",
        "file": "reprompt.log"
    },
    "output": {
        "format": "text",
        "file": "output.txt"
    },
    "error_handling": {
        "retry_attempts": 3,
        "log_errors": true
    },
    "features": {
        "enable_suggestions": true,
        "enable_feedback": true,
        "enable_custom_prompts": false
    }
}